global:
  security:
    allowInsecureImages: true
fullnameOverride: traefik
ingressClass:
  enabled: true
  isDefaultClass: false
  name: traefik
providers:
  kubernetesIngress:
    ingressClass: traefik
gateway:
  enabled: false
gatewayClass:
  enabled: false
api:
  dashboard: false
ports:
  web:
    forwardedHeaders:
      insecure: true
service:
  type: ClusterIP
